# ─────────────────────────────────────────────────────
# Home Brain — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────

# ── Camera (CP Plus CP-E44Q) ─────────────────────────
# Find your camera IP in your router's DHCP client list.
# Assign it a STATIC IP in your router settings first!
CAMERA_IP=192.168.1.XXX
CAMERA_PORT=554
CAMERA_USER=admin
CAMERA_PASS=your_camera_password

# Channel 1, subtype 1 = sub-stream (360p) — recommended
# subtype 0 = main stream (4MP/1440p) — only if you need quality
CAMERA_CHANNEL=1
CAMERA_SUBTYPE=1

# ── Storage ───────────────────────────────────────────
# Where to store clips and the SQLite database
DATA_DIR=./data

# How many days to keep clips locally before archiving to B2
RETENTION_DAYS=30

# ── Motion Detection ──────────────────────────────────
# Scene change sensitivity: 0.1 (very sensitive) → 0.5 (less sensitive)
# Start with 0.3 and tune based on false positives
SCENE_THRESHOLD=0.3

# Minimum clip duration to keep (seconds) — filters out micro-motion
MIN_CLIP_DURATION=5

# Maximum clip duration before splitting (seconds)
MAX_CLIP_DURATION=120

# Merge motion windows within this many seconds of each other
MERGE_GAP_S=10

# ── Development ───────────────────────────────────────
# How many seconds to record from the live stream.
# Leave at 86400 for production (full 24h).
# Set to 60 for test mode (python -m home_brain test).
RECORD_DURATION_S=86400

# ── Phase 2 — Intelligence Domain (not yet active) ────
# ANTHROPIC_API_KEY=sk-ant-...
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# ── Phase 3 — Memory Domain (not yet active) ──────────
# B2_APPLICATION_KEY_ID=...
# B2_APPLICATION_KEY=...
# B2_BUCKET_NAME=home-brain-archive
